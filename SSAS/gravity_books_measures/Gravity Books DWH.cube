  <MdxScripts>
    <MdxScript dwd:design-time-name="4e0f6e26-e4c7-42f3-8019-7f188d74cb87">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;  
CREATE MEMBER CURRENTCUBE.[Measures].[Average Order Value]
 AS [Measures].[Total Amount] / [Measures].[Sales Fact Count], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Average Unit Price]
 AS [Measures].[Total Amount] / [Measures].[Quantity], 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Books per Order]
 AS [Measures].[Quantity] / [Measures].[Sales Fact Count], 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>